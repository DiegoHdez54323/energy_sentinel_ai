# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/energy_sentinel_ai
CORS_ORIGIN=http://localhost:5173

# Auth
# Minimum 32 characters
JWT_SECRET=change_this_to_a_secure_secret_with_32_chars_min
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Shelly
SHELLY_OAUTH_REDIRECT_URI=https://your-backend.example.com/integrations/shelly/callback
SHELLY_POLLING_ENABLED=true
SHELLY_POLLING_INTERVAL_MS=60000
SHELLY_POLLING_BATCH_SIZE=100
SHELLY_POLLING_MAX_CONCURRENCY=3
SHELLY_POLLING_DEBUG_DUMPS=false

# Aggregates
AGGREGATES_ENABLED=true
AGGREGATES_INTERVAL_MS=3600000
AGGREGATES_DEVICE_BATCH_SIZE=100
