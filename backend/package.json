{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.dev.ts",
    "dev:web": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc && npm run copy:prisma-client",
    "copy:prisma-client": "node scripts/copy-prisma-client.mjs",
    "start": "npm run start:web",
    "start:web": "node dist/src/server.js",
    "job:shelly-polling": "node dist/src/jobs/job-shelly-polling.js",
    "job:aggregates": "node dist/src/jobs/job-aggregates.js",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "morgan": "^1.10.1",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
