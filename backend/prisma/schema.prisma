// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  homes             Home[]
  devices           Device[]
  shellyIntegration ShellyIntegration?

  pushTokens    UserPushToken[]
  notifications NotificationLog[]
  refreshTokens RefreshToken[]
  shellyOauthStates ShellyOAuthState[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Home {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  timezone  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices Device[]

  @@index([userId])
  @@map("homes")
}

model ShellyIntegration {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  clientId   String @default("shelly-diy") @map("client_id")
  userApiUrl String @map("user_api_url")

  authCode String? @map("auth_code")

  accessToken          String?   @map("access_token")
  accessTokenExpiresAt DateTime? @map("access_token_expires_at") @db.Timestamptz(6)

  status     String    @default("active")
  lastSyncAt DateTime? @map("last_sync_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shelly_integrations")
}

model ShellyOAuthState {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  state      String   @unique
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("shelly_oauth_states")
}

model Device {
  id String @id @default(uuid()) @db.Uuid

  homeId String @map("home_id") @db.Uuid
  userId String @map("user_id") @db.Uuid

  vendor      String
  deviceCode  String? @map("device_code")
  displayName String  @map("display_name")

  ipAddress  String? @map("ip_address") @db.Inet
  macAddress String? @map("mac_address")

  externalDeviceId String @map("external_device_id")

  status     String    @default("active")
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)

  dataSource String @default("shelly_cloud") @map("data_source")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  home Home @relation(fields: [homeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  readings    DeviceReading[]
  hourlyUsage DeviceUsageHourly[]
  dailyUsage  DeviceUsageDaily[]
  anomalyModels DeviceAnomalyModel[]
  readingFeatures DeviceReadingFeature[]
  anomalyPredictions DeviceAnomalyPrediction[]
  anomalies   AnomalyEvent[]

  @@unique([userId, externalDeviceId], map: "devices_user_external_unique")
  @@index([homeId])
  @@index([userId])
  @@map("devices")
}

model DeviceReading {
  id       BigInt   @id @default(autoincrement())
  deviceId String   @map("device_id") @db.Uuid
  ts       DateTime @db.Timestamptz(6)

  apower  Decimal? @db.Decimal(12, 4)
  voltage Decimal? @db.Decimal(12, 4)
  current Decimal? @db.Decimal(12, 4)
  freq    Decimal? @db.Decimal(8, 4)
  output  Boolean?

  aenergyTotal    Decimal? @map("aenergy_total") @db.Decimal(12, 4)
  aenergyDelta    Decimal? @map("aenergy_delta") @db.Decimal(12, 4)
  aenergyMinuteTs BigInt?  @map("aenergy_minute_ts")
  aenergyByMinute Json?    @map("aenergy_by_minute") @db.JsonB

  retAenergyTotal    Decimal? @map("ret_aenergy_total") @db.Decimal(12, 4)
  retAenergyMinuteTs BigInt?  @map("ret_aenergy_minute_ts")
  retAenergyByMinute Json?    @map("ret_aenergy_by_minute") @db.JsonB

  temperatureTc Decimal? @map("temperature_tc") @db.Decimal(8, 4)
  temperatureTf Decimal? @map("temperature_tf") @db.Decimal(8, 4)

  source String @default("shelly_cloud")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  features DeviceReadingFeature[]
  anomalyPredictions DeviceAnomalyPrediction[]
  anomalies AnomalyEvent[]

  @@unique([deviceId, ts], map: "device_readings_device_ts_unique")
  @@index([deviceId, ts])
  @@map("device_readings")
}

model DeviceUsageHourly {
  id       BigInt   @id @default(autoincrement())
  deviceId String   @map("device_id") @db.Uuid
  hourTs   DateTime @map("hour_ts") @db.Timestamptz(6)

  energyWh     Decimal  @map("energy_wh") @db.Decimal(14, 4)
  avgPowerW    Decimal? @map("avg_power_w") @db.Decimal(12, 4)
  maxPowerW    Decimal? @map("max_power_w") @db.Decimal(12, 4)
  minPowerW    Decimal? @map("min_power_w") @db.Decimal(12, 4)
  samplesCount Int      @map("samples_count")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, hourTs], map: "device_usage_hourly_device_hour_unique")
  @@index([deviceId])
  @@map("device_usage_hourly")
}

model DeviceUsageDaily {
  id       BigInt   @id @default(autoincrement())
  deviceId String   @map("device_id") @db.Uuid
  date     DateTime @db.Date

  energyWh     Decimal  @map("energy_wh") @db.Decimal(14, 4)
  avgPowerW    Decimal? @map("avg_power_w") @db.Decimal(12, 4)
  maxPowerW    Decimal? @map("max_power_w") @db.Decimal(12, 4)
  minPowerW    Decimal? @map("min_power_w") @db.Decimal(12, 4)
  samplesCount Int      @map("samples_count")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, date], map: "device_usage_daily_device_date_unique")
  @@index([deviceId])
  @@map("device_usage_daily")
}

model DeviceAnomalyModel {
  id       String @id @default(uuid()) @db.Uuid
  deviceId String @map("device_id") @db.Uuid

  modelType            String   @default("isolation_forest") @map("model_type")
  modelVersion         String   @map("model_version")
  featureSchemaVersion String   @map("feature_schema_version")
  contamination        Float
  trainingWindowDays   Int      @map("training_window_days")
  trainedFrom          DateTime @map("trained_from") @db.Date
  trainedTo            DateTime @map("trained_to") @db.Date
  trainedAt            DateTime @map("trained_at") @db.Timestamptz(6)
  trainingSampleCount  Int      @map("training_sample_count")
  timezone             String
  artifact             Json     @db.JsonB
  summary      Json?  @db.JsonB

  isActive     Boolean   @default(true) @map("is_active")
  status       String    @default("active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  supersededAt DateTime? @map("superseded_at") @db.Timestamptz(6)

  device        Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  predictions   DeviceAnomalyPrediction[]
  anomalyEvents AnomalyEvent[]

  @@index([deviceId])
  @@index([deviceId, isActive])
  @@map("device_anomaly_models")
}

model DeviceReadingFeature {
  id         BigInt  @id @default(autoincrement())
  readingId   BigInt  @map("reading_id")
  deviceId    String  @map("device_id") @db.Uuid
  ts          DateTime @db.Timestamptz(6)
  localDate   DateTime @map("local_date") @db.Date

  featureSchemaVersion String @map("feature_schema_version")
  timezone             String
  dayGroup             String  @map("day_group")
  localHour            Int     @map("local_hour")
  dayOfWeek            Int     @map("day_of_week")

  apower          Float?
  aenergyDelta    Float?  @map("aenergy_delta")
  outputNumeric   Float?  @map("output_numeric")
  hourSin         Float   @map("hour_sin")
  hourCos         Float   @map("hour_cos")
  dayOfWeekSin    Float   @map("day_of_week_sin")
  dayOfWeekCos    Float   @map("day_of_week_cos")
  deltaPowerPrev  Float?  @map("delta_power_prev")
  rollingMeanPower5 Float? @map("rolling_mean_power_5")
  rollingStdPower5  Float? @map("rolling_std_power_5")

  reading DeviceReading @relation(fields: [readingId], references: [id], onDelete: Cascade)
  device  Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([readingId, featureSchemaVersion], map: "device_reading_features_reading_version_unique")
  @@index([deviceId, ts])
  @@index([deviceId, localDate])
  @@map("device_reading_features")
}

model DeviceAnomalyPrediction {
  id        String   @id @default(uuid()) @db.Uuid
  readingId BigInt   @unique(map: "device_anomaly_predictions_reading_unique") @map("reading_id")
  deviceId  String   @map("device_id") @db.Uuid
  modelId   String?  @map("model_id") @db.Uuid

  scoredAt          DateTime @map("scored_at") @db.Timestamptz(6)
  score             Float?
  decisionFunction  Float?   @map("decision_function")
  isAnomaly         Boolean? @map("is_anomaly")
  status            String
  details           Json?    @db.JsonB

  reading DeviceReading @relation(fields: [readingId], references: [id], onDelete: Cascade)
  device  Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  model   DeviceAnomalyModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  anomalyEvent AnomalyEvent?

  @@index([deviceId, scoredAt])
  @@index([modelId])
  @@map("device_anomaly_predictions")
}

model AnomalyEvent {
  id         String  @id @default(uuid()) @db.Uuid
  deviceId   String  @map("device_id") @db.Uuid
  modelId    String? @map("model_id") @db.Uuid
  predictionId String? @unique(map: "anomaly_events_prediction_unique") @map("prediction_id") @db.Uuid
  readingId  BigInt? @unique(map: "anomaly_events_reading_unique") @map("reading_id")

  detectedAt  DateTime @map("detected_at") @db.Timestamptz(6)
  windowStart DateTime @map("window_start") @db.Timestamptz(6)
  windowEnd   DateTime @map("window_end") @db.Timestamptz(6)

  anomalyType String   @map("anomaly_type")
  severity    Int      @db.SmallInt
  score       Decimal? @db.Decimal(12, 4)

  expectedValue Decimal? @map("expected_value") @db.Decimal(12, 4)
  observedValue Decimal? @map("observed_value") @db.Decimal(12, 4)

  details Json? @db.JsonB

  device        Device            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  model         DeviceAnomalyModel?   @relation(fields: [modelId], references: [id], onDelete: SetNull)
  prediction    DeviceAnomalyPrediction? @relation(fields: [predictionId], references: [id], onDelete: SetNull)
  reading       DeviceReading? @relation(fields: [readingId], references: [id], onDelete: SetNull)
  notifications NotificationLog[]

  @@index([deviceId, detectedAt])
  @@map("anomaly_events")
}

model UserPushToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  token      String    @unique
  platform   String?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_push_tokens")
}

model NotificationLog {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  anomalyEventId String?  @map("anomaly_event_id") @db.Uuid
  sentAt         DateTime @map("sent_at") @db.Timestamptz(6)
  channel        String   @default("fcm")
  status         String
  errorMessage   String?  @map("error_message")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  anomalyEvent AnomalyEvent? @relation(fields: [anomalyEventId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
  @@index([anomalyEventId])
  @@map("notification_logs")
}

model JobLock {
  key       String   @id
  ownerId   String   @map("owner_id")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("job_locks")
}
